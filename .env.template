# Environment Configuration Template
# Copy this file to .env and fill in the values.

# Application Environment — local | prod
ENV=local

# Server host (only required when ENV != local)
HOST=http://127.0.0.1

# Port the HTTP server listens on
PORT=4690

# Path to the SQLite database file
DB_PATH=./tmp/db.sql

# Goose migration configuration (used by the `goose` CLI in `task db/*`).
# The app itself runs migrations via the goose library at startup.
GOOSE_DRIVER=sqlite3
GOOSE_DBSTRING=./tmp/db.sql
GOOSE_MIGRATION_DIR=./db/migrations

# App metadata
APP_NAME="Two Cents"
APP_VERSION=0.0.0

# Hex-encoded symmetric key used to encrypt secrets at rest (e.g. stored bank
# access tokens). Required. Generate one with: openssl rand -hex 32
ENCRYPTION_KEY=

# Plaid
# App credentials from the Plaid dashboard (Trial plan, "Personal use").
# Both are required.
PLAID_CLIENT_ID=
PLAID_SECRET=
# Plaid environment: sandbox | production (Trial plan uses production).
PLAID_ENV=production
# Comma-separated Plaid country codes and products.
PLAID_COUNTRY_CODES=US
PLAID_PRODUCTS=transactions
